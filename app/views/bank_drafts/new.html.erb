<% content_for :title, "Issue Bank Draft - BankCORE" %>

<div class="w-full max-w-lg">
  <%= link_to "← Back to Bank Drafts", bank_drafts_path, class: "link link-primary mb-4 inline-block" %>

  <div class="card bg-base-200 shadow-sm">
    <div class="card-body">
      <h1 class="card-title text-xl mb-4">Issue Bank Draft</h1>
      <% if flash[:alert] %>
        <div class="alert alert-error mb-4"><%= flash[:alert] %></div>
      <% end %>

      <%= form_with url: bank_drafts_path, method: :post, local: true, class: "space-y-4" do |f| %>
        <div class="form-control w-full">
          <label class="label" for="instrument_type">
            <span class="label-text">Instrument Type</span>
          </label>
          <select name="instrument_type" id="instrument_type" class="select select-bordered w-full" required>
            <option value="cashiers_check" <%= "selected" if @bank_draft_params["instrument_type"] == "cashiers_check" %>>Cashier's Check</option>
            <option value="money_order" <%= "selected" if @bank_draft_params["instrument_type"] == "money_order" %>>Money Order</option>
          </select>
        </div>

        <div class="form-control w-full">
          <label class="label" for="remitter_party_id">
            <span class="label-text">Remitter (Purchaser)</span>
          </label>
          <select name="remitter_party_id" id="remitter_party_id" class="select select-bordered w-full" required>
            <option value="">— Select remitter —</option>
            <% @parties.each do |party| %>
              <option value="<%= party.id %>" <%= "selected" if @bank_draft_params["remitter_party_id"].to_s == party.id.to_s %>>
                <%= party.display_name %> (<%= party.party_number %>)
              </option>
            <% end %>
          </select>
          <label class="label">
            <span class="label-text-alt">The party purchasing the draft. Account must belong to this party.</span>
          </label>
        </div>

        <div class="form-control w-full">
          <label class="label" for="account_id">
            <span class="label-text">Account to Debit</span>
          </label>
          <select name="account_id" id="account_id" class="select select-bordered w-full" required>
            <option value="">— Select account —</option>
            <% @accounts.each do |account| %>
              <option value="<%= account.id %>" <%= "selected" if @bank_draft_params["account_id"].to_s == account.id.to_s %>>
                <%= account.account_number %> — <%= account.account_reference %> (<%= number_to_currency((account.account_balances.first&.available_balance_cents || 0) / 100.0) %>)
              </option>
            <% end %>
          </select>
        </div>

        <div class="form-control w-full">
          <label class="label" for="amount">
            <span class="label-text">Amount</span>
          </label>
          <input type="number" name="amount" id="amount" step="0.01" min="0.01" class="input input-bordered w-full" placeholder="0.00" value="<%= @bank_draft_params["amount"] %>" required>
        </div>

        <div class="form-control w-full">
          <label class="label" for="payee_name">
            <span class="label-text">Pay to the Order of</span>
          </label>
          <input type="text" name="payee_name" id="payee_name" class="input input-bordered w-full" placeholder="Payee name" value="<%= @bank_draft_params["payee_name"] %>" required>
        </div>

        <div class="form-control w-full">
          <label class="label" for="branch_id">
            <span class="label-text">Branch</span>
          </label>
          <select name="branch_id" id="branch_id" class="select select-bordered w-full" required>
            <option value="">— Select branch —</option>
            <% @branches.each do |branch| %>
              <option value="<%= branch.id %>" <%= "selected" if @bank_draft_params["branch_id"].to_s == branch.id.to_s %>>
                <%= branch.branch_code %> — <%= branch.name %>
              </option>
            <% end %>
          </select>
        </div>

        <div class="form-control w-full">
          <label class="label" for="memo">
            <span class="label-text">Memo (optional)</span>
          </label>
          <input type="text" name="memo" id="memo" class="input input-bordered w-full" value="<%= @bank_draft_params["memo"] %>">
        </div>

        <div class="form-control w-full">
          <label class="label" for="expires_at">
            <span class="label-text">Expires At (optional)</span>
          </label>
          <input type="date" name="expires_at" id="expires_at" class="input input-bordered w-full" value="<%= @bank_draft_params["expires_at"] %>">
        </div>

        <div class="flex gap-2 pt-4">
          <button type="submit" class="btn btn-primary">Issue Draft</button>
          <%= link_to "Cancel", bank_drafts_path, class: "btn btn-ghost" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
