<% content_for :title, "Business Dates - BankCORE" %>

<div class="w-full">
  <div class="workspace-header">
    <div>
      <%= link_to "← Back", root_path, class: "link link-primary mb-2 inline-block text-sm" %>
      <h1 class="workspace-title">Business Date Control</h1>
      <p class="workspace-subtitle">Monitor the current accounting day, review historical open and closed dates, and run the controlled close-and-advance step.</p>
    </div>
  </div>

  <section class="<%= @current_open ? 'ui-panel' : 'ui-panel-warning' %> mb-6">
    <div class="ui-panel-body">
      <% if @current_open %>
        <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
          <div class="space-y-2">
            <div class="flex flex-wrap items-center gap-2">
              <span class="business-date-badge">Current Date <%= @current_open.business_date.strftime("%Y-%m-%d") %></span>
              <span class="<%= status_pill_class(@current_open.status) %>"><%= @current_open.status %></span>
            </div>
            <p class="text-sm text-base-content/70">The current accounting day remains open for posting. Closing the date advances the business day and opens the next controlled posting window.</p>
          </div>

          <%= button_to "Close & Advance to Next Day",
              close_business_date_path(@current_open),
              method: :post,
              form: { data: { turbo_confirm: "Close this business date and open the next? This cannot be undone." } },
              class: "btn btn-primary" %>
        </div>
      <% else %>
        <div class="space-y-2">
          <div class="flex flex-wrap items-center gap-2">
            <span class="<%= status_pill_class('closed') %>">No Open Date</span>
          </div>
          <p class="text-sm text-base-content/75">No open business date is available. Seed or reopen the operating day before transaction-critical work resumes.</p>
        </div>
      <% end %>
    </div>
  </section>

  <div class="grid gap-4 lg:grid-cols-3 mb-6">
    <div class="ui-metric">
      <div class="ui-metric-label">Tracked Dates</div>
      <div class="ui-metric-value ui-mono"><%= @business_dates.size %></div>
    </div>
    <div class="ui-metric">
      <div class="ui-metric-label">Open Dates</div>
      <div class="ui-metric-value ui-mono"><%= @business_dates.count { |bd| bd.status == Bankcore::Enums::BUSINESS_DATE_OPEN } %></div>
    </div>
    <div class="ui-metric">
      <div class="ui-metric-label">Latest Closed Date</div>
      <div class="ui-metric-value ui-mono"><%= @business_dates.detect { |bd| bd.status == Bankcore::Enums::BUSINESS_DATE_CLOSED }&.business_date&.strftime("%Y-%m-%d") || "—" %></div>
    </div>
  </div>

  <section class="ui-panel">
    <div class="ui-panel-header">
      <div>
        <h2 class="text-lg font-semibold text-base-content">Date Register</h2>
        <p class="mt-1 text-sm text-base-content/65">Recent business dates with current status and open/close timestamps.</p>
      </div>
    </div>

    <div class="ui-panel-body">
      <table class="ui-ledger-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Status</th>
            <th>Opened At</th>
            <th>Closed At</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @business_dates.each do |bd| %>
            <tr>
              <td class="ui-mono"><%= bd.business_date.strftime("%Y-%m-%d") %></td>
              <td><span class="<%= status_pill_class(bd.status) %>"><%= bd.status %></span></td>
              <td class="ui-mono"><%= bd.opened_at&.strftime("%Y-%m-%d %H:%M") || "—" %></td>
              <td class="ui-mono"><%= bd.closed_at&.strftime("%Y-%m-%d %H:%M") || "—" %></td>
              <td><%= link_to "View", business_date_path(bd), class: "btn btn-ghost btn-xs" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <% if @business_dates.empty? %>
        <p class="mt-4 text-sm text-base-content/60">No business dates. Run `db:seed` to create one.</p>
      <% end %>
    </div>
  </section>
</div>
