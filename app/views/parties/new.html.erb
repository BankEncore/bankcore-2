<% content_for :title, "New Party - BankCORE" %>

<div class="w-full max-w-md">
  <%= link_to "← Back to Parties", parties_path, class: "link link-primary mb-4 inline-block" %>

  <div class="card bg-base-200 shadow-sm">
    <div class="card-body">
      <h1 class="card-title text-xl mb-4">New Party</h1>
      <% if params[:return_to].present? %>
        <div class="mb-4 rounded-lg border border-base-300 bg-base-100 px-4 py-3 text-sm text-base-content/75">
          Create the customer record first, then continue directly into account opening.
        </div>
      <% end %>
      <%= render "form" %>
    </div>
  </div>
</div>
