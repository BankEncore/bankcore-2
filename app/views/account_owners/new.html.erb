<% content_for :title, "Add Owner - BankCORE" %>

<div class="w-full max-w-md">
  <%= link_to "← Back to Account", account_path(@account), class: "link link-primary mb-4 inline-block" %>

  <div class="card bg-base-200 shadow-sm">
    <div class="card-body">
      <h1 class="card-title text-xl mb-4">Add Owner to Account <%= @account.account_number %></h1>

      <%= form_with model: @account_owner, url: account_account_owners_path(@account), method: :post, local: true, class: "space-y-4" do |f| %>
        <% if @account_owner.errors.any? %>
          <div class="alert alert-error">
            <span><%= @account_owner.errors.full_messages.to_sentence %></span>
          </div>
        <% end %>

        <div class="form-control w-full">
          <label class="label" for="account_owner_party_id">
            <span class="label-text">Party</span>
          </label>
          <%= f.select :party_id,
              options_from_collection_for_select(@parties, :id, :display_name, @account_owner.party_id),
              { include_blank: "— Select party —" },
              { class: "select select-bordered w-full", required: true } %>
        </div>

        <div class="form-control w-full">
          <label class="label" for="account_owner_role_type">
            <span class="label-text">Role (optional)</span>
          </label>
          <%= f.text_field :role_type, class: "input input-bordered w-full", placeholder: "e.g. primary" %>
        </div>

        <div class="form-control">
          <label class="label cursor-pointer justify-start gap-2">
            <%= f.check_box :is_primary, class: "checkbox checkbox-sm" %>
            <span class="label-text">Primary owner</span>
          </label>
        </div>

        <div class="flex gap-2 pt-4">
          <button type="submit" class="btn btn-primary">Add Owner</button>
          <%= link_to "Cancel", account_path(@account), class: "btn btn-ghost" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
