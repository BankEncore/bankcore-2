<section class="rounded-2xl border border-base-300 bg-base-100 p-4">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-base-content/60"><%= title %></h3>
      <% if account_payload.present? %>
        <p class="mt-1 text-base font-semibold text-base-content">
          <span class="ui-mono"><%= account_payload[:account_number] %></span>
          <span class="text-base-content/60">·</span>
          <%= account_payload[:product_name] %>
        </p>
      <% else %>
        <p class="mt-1 text-sm text-base-content/60"><%= empty_text %></p>
      <% end %>
    </div>
    <% if account_payload.present? %>
      <span class="<%= account_payload[:status_class] %>"><%= account_payload[:status] %></span>
    <% end %>
  </div>

  <% if account_payload.present? %>
    <div class="mt-4 space-y-3">
      <div class="ui-kv-row">
        <div class="ui-kv-label">Primary Owner</div>
        <div class="ui-kv-value"><%= account_payload[:primary_owner_name].presence || "—" %></div>
      </div>
      <div class="ui-kv-row">
        <div class="ui-kv-label">Reference</div>
        <div class="ui-kv-value ui-mono"><%= account_payload[:account_reference] %></div>
      </div>
      <div class="ui-kv-row">
        <div class="ui-kv-label">Account Type</div>
        <div class="ui-kv-value"><%= account_payload[:account_type] %></div>
      </div>
      <div class="ui-kv-row">
        <div class="ui-kv-label">Available Balance</div>
        <div class="ui-kv-value ui-mono"><%= account_payload[:available_balance_display] %></div>
      </div>
      <div class="ui-kv-row">
        <div class="ui-kv-label">Posted Balance</div>
        <div class="ui-kv-value ui-mono"><%= account_payload[:posted_balance_display] %></div>
      </div>
      <div class="ui-kv-row">
        <div class="ui-kv-label">Currency</div>
        <div class="ui-kv-value ui-mono"><%= account_payload[:currency_code] %></div>
      </div>
      <div class="ui-kv-row">
        <div class="ui-kv-label">Branch</div>
        <div class="ui-kv-value"><%= account_payload[:branch_code].presence || "—" %></div>
      </div>
    </div>
  <% end %>
</section>
