<% content_for :title, "New Transaction - BankCORE" %>

<div class="w-full">
  <div class="workspace-header">
    <div>
      <%= link_to "← Back to Transactions", transactions_path, class: "link link-primary mb-2 inline-block text-sm" %>
      <h1 class="workspace-title">Transaction Workstation</h1>
      <p class="workspace-subtitle">Use the shared shell for adjustments, transfers, fees, and ACH. Interest workflows and reversals use dedicated operator workbenches.</p>
    </div>
  </div>

  <div class="grid gap-6 xl:grid-cols-12">
    <div class="space-y-6 xl:col-span-4">
      <section class="ui-panel">
        <div class="ui-panel-header">
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-base-content/60">Transaction Context</h2>
        </div>
        <div class="ui-panel-body">
          <div class="space-y-4">
            <div class="ui-kv-row">
              <div class="ui-kv-label">Business Date</div>
              <div class="ui-kv-value ui-mono"><%= @business_date&.strftime("%Y-%m-%d") %></div>
            </div>
            <div class="ui-kv-row">
              <div class="ui-kv-label">Operator</div>
              <div class="ui-kv-value"><%= workspace_user_label %></div>
            </div>
            <div>
              <div class="ui-kv-label mb-3">Selected Account</div>
              <div id="account_context_panels" data-transaction-workstation-target="accountContextPanels">
                <%= render "transactions/account_context_panels",
                    transfer_mode: params.dig(:transaction, :transaction_code) == "XFER_INTERNAL",
                    single_account_payload: @selected_account_payload,
                    source_account_payload: @selected_source_account_payload,
                    destination_account_payload: @selected_destination_account_payload %>
              </div>
            </div>
            <div class="ui-kv-row">
              <div class="ui-kv-label">Workflow Mode</div>
              <div id="transaction_guidance" class="ui-kv-value" data-transaction-workstation-target="guidance">Choose a transaction code to load the required controls.</div>
            </div>
          </div>
        </div>
      </section>

      <section class="ui-panel-muted">
        <div class="ui-panel-header">
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-base-content/60">Shared Rules</h2>
        </div>
        <div class="ui-panel-body space-y-3 text-sm text-base-content/75">
          <p>All workstation submissions fail closed if the business date is closed, the amount is invalid, or the routing targets do not resolve.</p>
          <p>Preview lets you inspect the derived posting legs before any operational transaction or side record is created.</p>
        </div>
      </section>

      <section class="ui-panel">
        <div class="ui-panel-header">
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-base-content/60">Dedicated Workbenches</h2>
        </div>
        <div class="ui-panel-body space-y-3">
          <%= link_to "Run Interest Accrual", interest_accruals_path, class: "btn btn-outline w-full justify-start" %>
          <%= link_to "Run Interest Posting", interest_postings_path, class: "btn btn-outline w-full justify-start" %>
          <div class="rounded-2xl border border-base-300/70 px-4 py-3 text-sm text-base-content/75">
            Reversals are previewed and confirmed from each transaction review screen so override thresholds stay explicit.
          </div>
        </div>
      </section>
    </div>

    <div class="xl:col-span-8">
      <section class="ui-panel">
        <div class="ui-panel-header">
          <div>
            <h2 class="text-lg font-semibold text-base-content">Shared Transaction Shell</h2>
            <p class="mt-1 text-sm text-base-content/65">The policy layer validates family-specific inputs before previewing or dispatching to the correct posting path.</p>
          </div>
        </div>

        <div class="ui-panel-body">
          <% if flash[:alert].present? %>
            <div class="ui-panel-critical mb-4">
              <div class="ui-panel-body py-3">
                <div class="flex items-start gap-3">
                  <span class="<%= status_pill_class('error') %>">Validation</span>
                  <p class="text-sm text-base-content"><%= flash[:alert] %></p>
                </div>
              </div>
            </div>
          <% end %>

          <%= form_with url: transactions_path,
                        method: :post,
                        local: true,
                        class: "space-y-5",
                        data: {
                          controller: "transaction-workstation",
                          action: "submit->transaction-workstation#validateForm account-picker:changed->transaction-workstation#updateContext"
                        } do %>
            <section class="ui-form-section">
              <div>
                <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-base-content/60">Posting Instruction</h3>
              </div>

              <div class="grid gap-4 lg:grid-cols-2">
                <div class="form-control w-full">
                  <label class="label" for="transaction_code">
                    <span class="label-text text-sm font-medium">Transaction Type</span>
                  </label>
                  <select name="transaction[transaction_code]"
                          id="transaction_code"
                          class="select select-bordered w-full"
                          required
                          data-action="change->transaction-workstation#updateFields"
                          data-transaction-workstation-target="typeSelect">
                    <option value="">— Select type —</option>
                    <% @transaction_codes.each do |tc| %>
                      <option value="<%= tc.code %>" <%= "selected" if params.dig(:transaction, :transaction_code) == tc.code %>><%= tc.code %> — <%= tc.description %></option>
                    <% end %>
                  </select>
                </div>

                <div class="form-control w-full">
                  <label class="label" for="amount">
                    <span id="amount_label" class="label-text text-sm font-medium" data-transaction-workstation-target="amountLabel">Amount (USD)</span>
                  </label>
                  <input type="number"
                         name="transaction[amount]"
                         id="amount"
                         step="0.01"
                         min="0"
                         value="<%= params.dig(:transaction, :amount) %>"
                         class="input input-bordered w-full ui-mono text-lg"
                         placeholder="0.00"
                         required
                         data-transaction-workstation-target="amountInput">
                </div>
              </div>
            </section>

            <section class="ui-form-section">
              <div>
                <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-base-content/60">Account Routing</h3>
              </div>

              <div id="account_fields" class="w-full" data-transaction-workstation-target="accountFields">
                <%= render "transactions/account_picker",
                    field_name: "transaction[account_id]",
                    field_id: "account_id",
                    label: "Account",
                    selected_id: @preselected_account_id || params.dig(:transaction, :account_id),
                    selected_account_payload: @selected_account_payload,
                    picker_target: "singlePicker" %>
              </div>

              <%= render "transactions/transfer_fields" %>
            </section>

            <section class="ui-form-section space-y-4">
              <div>
                <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-base-content/60">Family Controls</h3>
                <p class="mt-1 text-sm text-base-content/65">Select a transaction type to load any family-specific controls that apply.</p>
              </div>

              <%= render "transactions/adjustment_fields" %>
              <%= render "transactions/fee_fields" %>
              <%= render "transactions/ach_fields" %>
            </section>

            <section class="ui-form-section">
              <div>
                <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-base-content/60">Control Metadata</h3>
              </div>

              <%= render "transactions/shared_metadata_fields" %>
            </section>

            <div class="ui-review-banner">
              Preview lets you inspect the planned ledger impact before commit. Posting immediately will create the operational transaction and the family-specific side effects in one controlled step.
            </div>

            <div class="ui-confirm-strip">
              <p class="max-w-2xl text-sm text-base-content/70">Commit actions are deliberate. The dispatcher will route shared-shell transactions through the correct family path after policy validation.</p>
              <div class="flex flex-wrap items-center gap-2">
                <button type="submit" name="preview" value="1" class="btn btn-outline">Preview Posting</button>
                <button type="submit" class="btn btn-primary">Post Transaction</button>
                <%= link_to "Cancel", transactions_path, class: "btn btn-ghost" %>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    </div>
  </div>
</div>
