<% content_for :title, "Override Requests - BankCORE" %>

<div class="w-full">
  <% pending_count = @override_requests.count { |req| req.status == "pending" } %>

  <div class="workspace-header">
    <div>
      <%= link_to "← Back", root_path, class: "link link-primary mb-2 inline-block text-sm" %>
      <h1 class="workspace-title">Override Requests</h1>
      <p class="workspace-subtitle">Review pending and completed control exceptions with explicit approval state and transaction linkage.</p>
    </div>
  </div>

  <div class="grid gap-4 lg:grid-cols-3 mb-6">
    <div class="ui-metric">
      <div class="ui-metric-label">Requests</div>
      <div class="ui-metric-value ui-mono"><%= @override_requests.size %></div>
    </div>
    <div class="ui-metric">
      <div class="ui-metric-label">Pending Approval</div>
      <div class="ui-metric-value ui-mono"><%= pending_count %></div>
    </div>
    <div class="ui-metric">
      <div class="ui-metric-label">Approved / Denied</div>
      <div class="ui-metric-value ui-mono"><%= @override_requests.size - pending_count %></div>
    </div>
  </div>

  <section class="ui-panel">
    <div class="ui-panel-header">
      <div>
        <h2 class="text-lg font-semibold text-base-content">Override Queue</h2>
        <p class="mt-1 text-sm text-base-content/65">Current approval requests and their linked operational transactions.</p>
      </div>
    </div>

    <div class="ui-panel-body">
      <table class="ui-ledger-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Type</th>
            <th>Status</th>
            <th>Requested By</th>
            <th>Transaction</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @override_requests.each do |req| %>
            <tr>
              <td class="ui-mono"><%= req.id %></td>
              <td><%= req.request_type %></td>
              <td><span class="<%= status_pill_class(req.status) %>"><%= req.status %></span></td>
              <td><%= req.requested_by&.display_name || req.requested_by&.username || "—" %></td>
              <td class="ui-mono">
                <% if req.operational_transaction_id.present? %>
                  <%= link_to "Txn ##{req.operational_transaction_id}", transaction_path(req.operational_transaction_id), class: "link link-primary" %>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="ui-mono"><%= req.created_at.strftime("%Y-%m-%d %H:%M") %></td>
              <td><%= link_to "View", override_request_path(req), class: "btn btn-ghost btn-xs" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <% if @override_requests.empty? %>
        <p class="mt-4 text-sm text-base-content/60">No override requests.</p>
      <% end %>
    </div>
  </section>
</div>
