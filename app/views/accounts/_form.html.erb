<%= form_with model: @account, local: true, class: "space-y-4" do |f| %>
  <% if @account.errors.any? %>
    <div class="alert alert-error mb-4">
      <ul class="list-disc list-inside">
        <% @account.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control w-full">
    <label class="label" for="account_account_number">
      <span class="label-text">Account Number</span>
    </label>
    <%= f.text_field :account_number, class: "input input-bordered w-full font-mono", placeholder: "e.g. 1001", required: true %>
  </div>

  <div class="form-control w-full">
    <label class="label" for="account_account_reference">
      <span class="label-text">Account Reference</span>
    </label>
    <%= f.text_field :account_reference, class: "input input-bordered w-full font-mono", placeholder: "Defaults to the account number if left blank" %>
  </div>

  <div class="form-control w-full">
    <label class="label" for="account_account_product_id">
      <span class="label-text">Account Product</span>
    </label>
    <%= f.collection_select :account_product_id,
        @account_products,
        :id,
        :name,
        { include_blank: "— Select product —" },
        class: "select select-bordered w-full",
        required: true %>
  </div>

  <div class="form-control w-full">
    <label class="label" for="account_branch_id">
      <span class="label-text">Branch</span>
    </label>
    <%= f.collection_select :branch_id, @branches, :id, :name, { include_blank: "— Select branch —" }, class: "select select-bordered w-full", required: true %>
  </div>

  <div class="form-control w-full">
    <% account_return_path = @selected_primary_party.present? ? new_account_path(party_id: @selected_primary_party.id) : new_account_path %>
    <%= render "party_picker",
        field_name: "account[primary_party_id]",
        field_id: "account_primary_party_id",
        label: "Primary Owner (optional)",
        selected_id: f.object.primary_party_id,
        selected_party_payload: @selected_primary_party_payload %>
    <label class="label">
      <span class="label-text-alt">Currency, deposit defaults, and overdraft behavior come from the selected product.</span>
      <span class="label-text-alt">
        <%= link_to "Create customer first", new_party_path(return_to: account_return_path), class: "link link-primary" %>
      </span>
    </label>
  </div>

  <div class="flex gap-2 pt-4">
    <%= f.submit "Create Account", class: "btn btn-primary" %>
    <%= link_to "Cancel", accounts_path, class: "btn btn-ghost" %>
  </div>
<% end %>
