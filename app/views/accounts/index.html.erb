<% content_for :title, "Accounts - BankCORE" %>

<div class="w-full">
  <% active_count = @accounts.count { |account| account.status == Bankcore::Enums::STATUS_ACTIVE } %>

  <div class="workspace-header">
    <div>
      <%= link_to "← Back", root_path, class: "link link-primary mb-2 inline-block text-sm" %>
      <h1 class="workspace-title">Accounts</h1>
      <p class="workspace-subtitle">Review active customer accounts, balances, and branch ownership before drilling into transaction and hold activity.</p>
    </div>
    <%= link_to "New Account", new_account_path, class: "btn btn-primary" %>
  </div>

  <div class="grid gap-4 lg:grid-cols-3 mb-6">
    <div class="ui-metric">
      <div class="ui-metric-label">Visible Accounts</div>
      <div class="ui-metric-value ui-mono"><%= @accounts.size %></div>
    </div>
    <div class="ui-metric">
      <div class="ui-metric-label">Active Accounts</div>
      <div class="ui-metric-value ui-mono"><%= active_count %></div>
    </div>
    <div class="ui-metric">
      <div class="ui-metric-label">Branch Coverage</div>
      <div class="ui-metric-value ui-mono"><%= @accounts.map(&:branch_id).compact.uniq.size %></div>
    </div>
  </div>

  <section class="ui-panel">
    <div class="ui-panel-header">
      <div>
        <h2 class="text-lg font-semibold text-base-content">Account Register</h2>
        <p class="mt-1 text-sm text-base-content/65">Operational view of active accounts and current posted balances.</p>
      </div>
    </div>
    <div class="ui-panel-body">
      <table class="ui-ledger-table">
        <thead>
          <tr>
            <th>Account</th>
            <th>Type</th>
            <th>Branch</th>
            <th>Status</th>
            <th class="text-right">Balance</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @accounts.each do |account| %>
            <% balance = account.account_balances.first %>
            <tr>
              <td class="ui-mono"><%= account.account_number %></td>
              <td><%= account.account_type %></td>
              <td><%= account.branch&.branch_code %></td>
              <td><span class="<%= status_pill_class(account.status) %>"><%= account.status %></span></td>
              <td class="ui-mono text-right"><%= number_to_currency((balance&.posted_balance_cents || 0) / 100.0) %></td>
              <td><%= link_to "View", account_path(account), class: "btn btn-ghost btn-sm" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
